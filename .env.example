# OmniLocal — Environment Variables

# Orchestrator webhook base URL
WEBHOOK_BASE_URL=http://orchestrator:8000

# Phase Worker URLs (Docker service names)
PHASE1_URL=http://phase1:8000
PHASE2_URL=http://phase2:8000
PHASE3_URL=http://phase3:8000
PHASE4_URL=http://phase4:8000
PHASE5_URL=http://phase5:8000

# Google Gemini API Key (for Phases that call LLM)
GEMINI_API_KEY=your_api_key_here
